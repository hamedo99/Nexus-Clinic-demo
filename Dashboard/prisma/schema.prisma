generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   @default("password123")
  name      String?
  role      Role     @default(SECRETARY)
  doctorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@map("users")
}

model Doctor {
  id                     String             @id @default(uuid())
  name                   String
  doctor_name_en  String?
  specialty              String
  slug                   String             @unique
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  address                String?
  subscriptionStatus     SubscriptionStatus @default(TRIAL)
  clinicLogo             String?
  clinicPhone            String?
  consultationPrice      Int?               @default(25000)
  patientsPerHour        Int?               @default(4)
  workingHours           Json?
  Maps_url               String?
  certificates_list      Json?
  doctor_name            String?
  profile_image_path     String?
  specialty_title        String?
  working_hours_schedule Json?
  years_of_experience    Int?               @default(0)
  disabledDaysOfWeek     Int[]              @default([5])
  clinic_locations       Json?
  appointments           Appointment[]
  blockedTimes           BlockedTime[]
  patients               Patient[]
  users                  User[]
 

  @@index([createdAt])
  @@map("doctors")
}

model Patient {
  id           String        @id @default(uuid())
  fullName     String
  phoneNumber  String        @unique
  birthDate    DateTime?
  gender       String?
  address      String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  doctorId     String?
  appointments Appointment[]
  doctor       Doctor?       @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@index([createdAt])
  @@index([fullName])
  @@map("patients")
}

model Appointment {
  id        String            @id @default(uuid())
  patientId String
  doctorId  String?
  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(PENDING)
  clinicLocation String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  isLocked  Boolean           @default(false)
  doctor    Doctor?           @relation(fields: [doctorId], references: [id])
  patient   Patient           @relation(fields: [patientId], references: [id])

  @@index([doctorId, startTime])
  @@index([doctorId, status, startTime])
  @@index([startTime, status])
  @@index([patientId])
  @@index([doctorId])
  @@map("appointments")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model BlockedTime {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())
  doctorId  String?
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([startTime, endTime])
  @@index([doctorId])
  @@map("blocked_time")
}

enum Role {
  ADMIN
  DOCTOR
  SECRETARY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  TRIAL
  DISABLED
}
